# 🔐 Authentication
# Generate a random 32-character string: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"

# Trust host for NextAuth (required for Docker/production)
AUTH_TRUST_HOST=true

# NextAuth URL (update with your domain)
NEXTAUTH_URL=https://localhost:3000

# Admin credentials
ADMIN_USERNAME=admin

# Run: node scripts/hash-password.js <your_password>
ADMIN_PASSWORD_HASH="REPLACE_WITH_HASH_FROM_SCRIPT"

# 🔒 Security
# WARNING: Only use in development with self-signed certificates
# Remove or set to 1 in production with valid SSL certificates
NODE_TLS_REJECT_UNAUTHORIZED=0