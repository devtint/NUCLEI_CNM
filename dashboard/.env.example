# 🔐 Authentication
# Generate a random 32-character string: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
# Run: node scripts/hash-password.js <your_password>
ADMIN_PASSWORD_HASH="REPLACE_WITH_HASH_FROM_SCRIPT"

# 🌐 Network Configuration (Optional)
# Comma-separated list of allowed origins for server actions
# ALLOWED_ORIGINS="localhost:3000,192.168.1.100:3000"
# ALLOWED_DEV_ORIGINS="192.168.1.100"

# 🛠️ Tool Binary Paths (Optional)
# By default, tools are found via system PATH.
# Only set these if tools are installed but NOT in your system PATH.
# NUCLEI_BINARY="/path/to/nuclei"
# SUBFINDER_BINARY="/path/to/subfinder"
# HTTPX_BINARY="/path/to/httpx"

# 💾 Database Path (Optional - for Docker)
# DATABASE_PATH="/app/data/nuclei.db"

# 🤖 AI Assistant (Optional)
# Get a free API key at https://console.groq.com
# GROQ_API_KEY="gsk_your_key_here"
# AI_MODEL="llama-3.1-8b-instant"
